# Backend local configuration example.
# Export these variables in the shell before running Django, or copy them into
# your deployment environment.

DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional AI configuration.
OPENAI_API_KEY=
AI_COACH_MODEL=gpt-5.5
AI_TRAINING_DECISION_PROVIDER=local
AI_TRAINING_DECISION_MODEL=gpt-5.5
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TRAINING_DECISION_MODEL=qwen3:8b
